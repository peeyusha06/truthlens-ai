# ============================================================
# TruthLens AI – Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────
# Local MongoDB (default). Change to Atlas URI for cloud.
MONGO_URI=mongodb://127.0.0.1:27017/truthlens

# ── AI Service (Python FastAPI) ──────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Hive AI API (Primary Deepfake Detector) ─────────────────
# Get your free key at: https://thehive.ai/
# Free tier: 1000 requests/month
HIVE_API_KEY=YOUR_HIVE_API_KEY_HERE

# ── Google Gemini API (Reasoning Layer) ─────────────────────
# Get your free key at: https://aistudio.google.com/
# Free tier: 60 requests/min, 1500 req/day
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Upload Settings ──────────────────────────────────────────
# Max file size in bytes (default: 10 MB)
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
